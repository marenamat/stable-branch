{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(curl *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(pip3 *:*)",
      "Bash(apk list:*)",
      "Bash(apk search:*)",
      "Bash(cargo *)",
      "Bash(ls *)",
      "Bash(sed *)",
      "Bash(grep *)",
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(cat /proc/*)",
      "Bash(grep * /proc/*)"
    ],
    "deny": [
      "Bash(npm *)"
    ]
  }
}

